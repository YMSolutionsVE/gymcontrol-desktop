{
  "name": "gymcontrol-desktop",
  "version": "2.1.2",
  "description": "GymControl by YM Solutions",
  "author": {
    "name": "YM Solutions",
    "email": "contacto@ymsolutions.online"
  },
  "main": "electron/main.cjs",
  "type": "module",
  "scripts": {
    "dev": "concurrently -k \"vite\" \"wait-on tcp:5173 && electron .\"",
    "build": "vite build",
    "dist": "vite build && electron-builder --win --publish never",
    "dist:publish": "vite build && electron-builder --win --publish always"
  },
  "build": {
    "appId": "com.ymsolutions.gymcontrol",
    "productName": "GymControl",
    "copyright": "Copyright © 2025 YM Solutions. Todos los derechos reservados.",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "public/**/*"
    ],
    "win": {
      "target": "nsis",
      "icon": "public/icon.ico",
      "signAndEditExecutable": false
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "installerIcon": "public/icon.ico",
      "uninstallerIcon": "public/icon.ico",
      "installerHeaderIcon": "public/icon.ico",
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "GymControl"
    },
    "publish": {
      "provider": "github",
      "owner": "YMSolutionsVE",
      "repo": "gymcontrol-desktop",
      "private": true
    }
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.39.0",
    "electron-updater": "^6.3.9",
    "exceljs": "^4.4.0",
    "jspdf": "^4.1.0",
    "jspdf-autotable": "^5.0.7",
    "papaparse": "^5.5.3",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^6.20.0",
    "recharts": "^3.7.0"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.2.0",
    "autoprefixer": "^10.4.20",
    "concurrently": "^8.2.0",
    "electron": "^28.0.0",
    "electron-builder": "^25.1.8",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17",
    "vite": "^5.0.0",
    "wait-on": "^7.2.0"
  }
}